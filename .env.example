# ─────────────────────────────────────────────────────────────────────────────
# Sample environment file. Copy to `.env` and fill in real values before running:
#
#   cp .env.example .env
#
# `.env` is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Which environment a `npm test` run targets. `local` is the default.
# TEST_ENV=local

# ─── local (docker-compose) ──────────────────────────────────────────────────
# Override the localhost default if your BE listens elsewhere.
# LOCAL_BASE_URL=http://localhost:8080

# Local standard user — used by both UI workerAuthedPage and API authClient.
USER_USERNAME=user@example.com
USER_PASSWORD=replace-me

# Local admin (optional — only when a test specifically needs admin).
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=replace-me

# ─── dev (shared remote BE) ──────────────────────────────────────────────────
# Required when running with TEST_ENV=dev.
DEV_BASE_URL=https://dev.example.com

DEV_USER_USERNAME=dev-user@example.com
DEV_USER_PASSWORD=replace-me

DEV_ADMIN_USERNAME=dev-admin@example.com
DEV_ADMIN_PASSWORD=replace-me

# ─── Database (read-only) ────────────────────────────────────────────────────
# Used by shared/db/*.js helpers. SELECT only — see CLAUDE.md hard rules.
# DB_URL=postgresql://postgres@localhost:5432/app_dev_db

# ─── Optional cross-browser ──────────────────────────────────────────────────
# Comma-separated. Default: chromium only.
# BROWSERS=chromium,firefox,webkit
